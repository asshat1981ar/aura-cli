# AURA Environment Configuration
# Copy this file to .env and fill in your values

# Environment
AURA_ENV=development
AURA_LOG_LEVEL=info

# API Configuration
AURA_API_HOST=0.0.0.0
AURA_API_PORT=8000
AURA_API_WORKERS=4

# Security
AURA_SECRET_KEY=your-secret-key-here-change-in-production
AURA_JWT_SECRET=your-jwt-secret-here-change-in-production
AURA_JWT_EXPIRY=24h

# Database
AURA_DB_PATH=./memory
AURA_DB_URL=sqlite:///./memory/aura.db

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# MCP Configuration
AURA_MCP_CONFIG_PATH=./.mcp.json
AURA_AUTO_PROVISION_MCP=false
AURA_AUTO_START_MCP_SERVERS=false

# MCP Server Auth Tokens
# Source .env.n8n for actual values; use these placeholders as a template.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_API_TOKEN=your-agent-api-token      # port 8001 — aura-dev-tools
AGENT_API_ENABLE_RUN=1                    # enable /run endpoint on port 8001
MCP_API_TOKEN=your-mcp-api-token          # port 8002 — aura-skills
MCP_CONTROL_TOKEN=your-mcp-control-token  # port 8003 — aura-control
AGENTIC_LOOP_TOKEN=your-agentic-loop-token # port 8006 — aura-agentic-loop
COPILOT_MCP_TOKEN=your-copilot-mcp-token  # port 8007 — aura-copilot

# Web UI
WEB_UI_URL=http://localhost:3000
WEB_API_URL=http://localhost:8000

# External Services
# GitHub
GITHUB_TOKEN=your-github-token
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# n8n
N8N_MCP_TOKEN=your-n8n-token
N8N_WEBHOOK_URL=http://localhost:5678

# Brave Search
BRAVE_API_KEY=your-brave-api-key

# Monitoring
PROMETHEUS_ENABLED=false
GRAFANA_ENABLED=false
SENTRY_DSN=your-sentry-dsn

# Feature Flags
AURA_ENABLE_SHADOW_MODE=false
AURA_FORCE_LEGACY_ORCHESTRATOR=false
AURA_ENABLE_NEW_ORCHESTRATOR=true
AURA_ENABLE_MCP_REGISTRY=true
