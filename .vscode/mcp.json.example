{
  "mcpServers": {
    "aura-dev-tools": {
      "type": "http",
      "url": "http://127.0.0.1:8001",
      "headers": {
        "Authorization": "Bearer ${env:AGENT_API_TOKEN}"
      }
    },
    "aura-skills": {
      "type": "http",
      "url": "http://127.0.0.1:8002",
      "headers": {
        "Authorization": "Bearer ${env:MCP_API_TOKEN}"
      }
    },
    "aura-control": {
      "type": "http",
      "url": "http://127.0.0.1:8003",
      "headers": {
        "Authorization": "Bearer ${env:MCP_CONTROL_TOKEN}"
      }
    },
    "aura-agentic-loop": {
      "type": "http",
      "url": "http://127.0.0.1:8006",
      "headers": {
        "Authorization": "Bearer ${env:AGENTIC_LOOP_TOKEN}"
      }
    },
    "aura-copilot": {
      "type": "http",
      "url": "http://127.0.0.1:8007",
      "headers": {
        "Authorization": "Bearer ${env:COPILOT_MCP_TOKEN}"
      }
    },
    "aura-sadd": {
      "type": "http",
      "url": "http://127.0.0.1:8020",
      "headers": {
        "Authorization": "Bearer ${env:SADD_MCP_TOKEN}"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "n8n-mcp": {
      "type": "http",
      "url": "http://localhost:5678/mcp-server/http",
      "headers": {
        "Authorization": "Bearer ${env:N8N_MCP_TOKEN}",
        "Accept": "application/json, text/event-stream"
      }
    }
  }
}
