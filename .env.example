# =============================================================================
# AURA CLI — Environment Configuration Reference
# =============================================================================
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# Variables marked [required] must be set for the relevant feature to work.
# Variables marked [optional] have a safe default and can be omitted.
# Variables marked [secret] should NEVER be committed to version control.
#
# Generate random tokens with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(43))"
# =============================================================================


# =============================================================================
# Core Runtime
# =============================================================================

# Deployment environment. Controls log verbosity defaults and safe-mode guards.
# Values: development | staging | production
AURA_ENV=development

# Log verbosity level.
# Values: debug | info | warn | error
AURA_LOG_LEVEL=info

# When set to "1", the CLI entrypoint does NOT chdir to the project root.
# Required for running pytest from the repo root without picking up the
# developer's own aura.config.json.
# Default: unset (chdir is performed)
AURA_SKIP_CHDIR=1

# When set to "true", goal execution is simulated — no LLM calls, no file writes.
# Mirrors the --dry-run CLI flag; useful for CI plan previews.
# Default: false
AURA_DRY_RUN=false

# Override the project root directory detected by the server.
# Default: current working directory at server startup.
# AURA_PROJECT_ROOT=/path/to/my/project

# Enable streaming log output to stdout in addition to structured JSON logs.
# Default: unset (JSON-only)
# AURA_LOG_STREAM=1

# Maximum time (seconds) a shell command spawned by /execute?tool=run may run.
# Clamped to [1.0, 60.0]. Default: 15
AURA_RUN_TOOL_TIMEOUT_S=15

# Maximum bytes captured from a /execute?tool=run subprocess output.
# Clamped to [1024, 262144]. Default: 65536 (64 KiB)
AURA_RUN_TOOL_MAX_OUTPUT_BYTES=65536

# Read chunk size (bytes) when streaming subprocess output via SSE.
# Clamped to [128, 8192]. Default: 1024
AURA_RUN_TOOL_READ_CHUNK_BYTES=1024

# Absolute path to the aura.config.json / settings.json to load.
# Default: auto-discovered (settings.json then aura.config.json in cwd)
# AURA_CONFIG_PATH=/path/to/aura.config.json


# =============================================================================
# API Configuration
# =============================================================================

# Host the FastAPI server binds to.
# Default: 0.0.0.0
AURA_API_HOST=0.0.0.0

# Port the FastAPI server listens on (port 8001 = aura-dev-tools MCP).
# Default: 8000 (bare uvicorn default); aura-dev-tools uses 8001
AURA_API_PORT=8001

# Number of uvicorn worker processes (for production deployments).
# Default: 1 (single worker is correct for the SQLite-only mode)
AURA_API_WORKERS=1

# Bearer token that guards all authenticated API endpoints.
# When unset, the server runs in open-access mode (no auth required).
# [secret] Set this before exposing the server on any network interface.
AGENT_API_TOKEN=your-agent-api-token

# Set to "1" to enable the POST /execute?tool=run shell-execution endpoint.
# Disabled by default — only enable in trusted environments.
AGENT_API_ENABLE_RUN=0

# MCP server port used by the GitHub bridge and capability manager.
# Default: 8001
MCP_SERVER_PORT=8001


# =============================================================================
# Model Routing
# =============================================================================

# OpenRouter API key — primary provider for cloud model routing.
# [secret] [required for cloud model usage]
OPENROUTER_API_KEY=your-openrouter-api-key

# Anthropic API key — used directly when routing to Claude models.
# [secret]
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI API key — used for GPT models and text-embedding-3-small embeddings.
# [secret]
OPENAI_API_KEY=your-openai-api-key

# Generic AURA API key (OpenRouter fallback; lower priority than OPENROUTER_API_KEY).
# [secret]
# AURA_API_KEY=your-aura-api-key

# Per-role model overrides. Each maps to a model ID accepted by OpenRouter.
# When unset, the value from aura.config.json model_routing is used.
# AURA_MODEL_ROUTING_CODE_GENERATION=anthropic/claude-3.5-sonnet
# AURA_MODEL_ROUTING_PLANNING=deepseek/deepseek-chat
# AURA_MODEL_ROUTING_ANALYSIS=google/gemini-2.5-flash
# AURA_MODEL_ROUTING_CRITIQUE=deepseek/deepseek-r1-0528
# AURA_MODEL_ROUTING_EMBEDDING=openai/text-embedding-3-small
# AURA_MODEL_ROUTING_FAST=google/gemini-2.0-flash-001
# AURA_MODEL_ROUTING_QUALITY=deepseek/deepseek-r1-0528

# Command to invoke a local LLM (e.g. llama.cpp server wrapper).
# When set, local model routing profiles are active.
# AURA_LOCAL_MODEL_COMMAND=llama-server --model /path/to/model.gguf

# Per-role local model routing overrides (profile names from aura.config.json).
# AURA_LOCAL_MODEL_ROUTING_PLANNING=android_planner
# AURA_LOCAL_MODEL_ROUTING_CODE_GENERATION=android_coder
# AURA_LOCAL_MODEL_ROUTING_EMBEDDING=android_embeddings

# LLM call timeout in seconds. Default: 60
AURA_LLM_TIMEOUT=60

# Paths to external CLI model wrappers (used by the Beads bridge and adapters).
# GEMINI_CLI_PATH=/usr/local/bin/gemini
# CODEX_CLI_PATH=/usr/local/bin/codex
# COPILOT_CLI_PATH=/usr/local/bin/copilot


# =============================================================================
# MCP Auth Tokens
# =============================================================================
#
# Each AURA MCP server (microservice) uses its own bearer token.
# Source .env.n8n for actual values in n8n integration setups.
#
# Generate each token:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Port assignments:
#   8001 — aura-dev-tools   (AGENT_API_TOKEN)
#   8002 — aura-skills      (MCP_API_TOKEN)
#   8003 — aura-control     (MCP_CONTROL_TOKEN)
#   8006 — aura-agentic-loop (AGENTIC_LOOP_TOKEN)
#   8007 — aura-copilot     (COPILOT_MCP_TOKEN)
#   8050 — aura-swarm       (no dedicated token; uses MCP_API_TOKEN)
# =============================================================================

# [secret] Port 8001 — aura-dev-tools MCP server
AGENT_API_TOKEN=your-agent-api-token

# [secret] Port 8002 — aura-skills MCP server
MCP_API_TOKEN=your-mcp-api-token

# [secret] Port 8003 — aura-control MCP server
MCP_CONTROL_TOKEN=your-mcp-control-token

# [secret] Port 8006 — aura-agentic-loop MCP server
AGENTIC_LOOP_TOKEN=your-agentic-loop-token

# [secret] Port 8007 — aura-copilot MCP server
COPILOT_MCP_TOKEN=your-copilot-mcp-token

# [secret] n8n instance-level MCP token (from n8n UI → Settings → MCP)
N8N_MCP_TOKEN=your-n8n-mcp-token


# =============================================================================
# Memory & Storage
# =============================================================================

# Base directory for all AURA persistent state (SQLite DBs, JSON queues).
# Default: ./memory (relative to the project root)
AURA_DB_PATH=./memory

# Full SQLite connection URL (used by components that accept a URL directly).
# Default: sqlite:///./memory/aura.db
AURA_DB_URL=sqlite:///./memory/aura.db

# Brain memory database path (absolute or relative to project root).
# Default: memory/brain_v2.db
# AURA_BRAIN_DB_PATH=memory/brain_v2.db

# Goal queue JSON file path.
# Default: memory/goal_queue.json
# AURA_GOAL_QUEUE_PATH=memory/goal_queue.json

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Redis is OPTIONAL. When REDIS_ENABLED=false (default), AURA uses single-writer
# SQLite mode. Enable only when running concurrent multi-agent pipelines.
# See docs/adr/ADR-002-redis-optionality.md for the full contract.

# Redis connection URL. Supports redis://, rediss:// (TLS), redis+unix://.
REDIS_URL=redis://localhost:6379/0

# Explicit opt-in to Redis. Must be "true" AND REDIS_URL must be reachable.
# Default: false
REDIS_ENABLED=false


# =============================================================================
# Feature Flags
# =============================================================================
# These flags gate experimental or in-progress features.
# Mark new experimental features with the [EXPERIMENTAL] convention;
# see CONTRIBUTING.md for the full convention.

# Enable the new multi-agent orchestrator (replaces legacy single-agent loop).
# Default: true (new orchestrator is now default)
AURA_ENABLE_NEW_ORCHESTRATOR=true

# Force the legacy single-agent orchestrator even when the new one is available.
# Use this as a quick rollback if the new orchestrator has regressions.
# Default: false
AURA_FORCE_LEGACY_ORCHESTRATOR=false

# [EXPERIMENTAL] Run the new orchestrator in shadow mode: executes both old and
# new orchestrators, logs divergences, but returns old orchestrator results.
# Default: false
AURA_ENABLE_SHADOW_MODE=false

# Enable the MCP service registry (lists all registered MCP servers on /discovery).
# Default: true
AURA_ENABLE_MCP_REGISTRY=true

# [EXPERIMENTAL] Enable strict Pydantic schema validation on all tool inputs/outputs.
# May reject requests that were previously accepted with loose typing.
# Default: false
AURA_STRICT_SCHEMA=false

# [EXPERIMENTAL] Enable the autonomous swarm mode (parallel agent fleet).
# Requires Redis to be enabled for safe cross-agent coordination.
# Default: 0 (disabled)
AURA_ENABLE_SWARM=0

# [EXPERIMENTAL] Enable Qdrant vector store backend for semantic memory.
# Default: unset (uses SQLite semantic memory backend)
# AURA_USE_QDRANT=1

# [EXPERIMENTAL] Enable LangSmith tracing for agent runs.
# Requires LANGSMITH_API_KEY to be set.
# AURA_ENABLE_LANGSMITH=1

# Agent SDK overrides (for programmatic usage via core/agent_sdk/).
# AURA_AGENT_SDK_MODEL=anthropic/claude-3.5-sonnet
# AURA_AGENT_SDK_MAX_TURNS=20
# AURA_AGENT_SDK_MAX_BUDGET=0.50
# AURA_AGENT_SDK_PERMISSION_MODE=default


# =============================================================================
# Observability
# =============================================================================

# Enable Prometheus /metrics endpoint scraping.
# Default: false
PROMETHEUS_ENABLED=false

# Enable Grafana dashboard integration.
# Default: false
GRAFANA_ENABLED=false

# Sentry DSN for error tracking and performance monitoring.
# When unset, Sentry is disabled.
# [secret]
SENTRY_DSN=your-sentry-dsn

# Webhook URL for critical AURA alerts (goal failures, health degradation, etc.).
# When unset, alert webhooks are disabled.
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# LangSmith API key for agent tracing (requires AURA_ENABLE_LANGSMITH=1).
# [secret]
# LANGSMITH_API_KEY=your-langsmith-api-key


# =============================================================================
# Security
# =============================================================================

# Secret key used for signing internal AURA session tokens.
# [secret] [required in production] Change from the default before deployment.
AURA_SECRET_KEY=your-secret-key-here-change-in-production

# JWT secret for signing API access tokens (RS256 or HS256 depending on config).
# [secret] [required when AUTH_ENABLED=true]
JWT_SECRET_KEY=your-jwt-secret-here-change-in-production

# Legacy alias kept for backward compatibility with older config consumers.
# Prefer JWT_SECRET_KEY for new usage.
AURA_JWT_SECRET=your-jwt-secret-here-change-in-production

# JWT token expiry duration. Accepts Go-style duration strings.
# Default: 24h
AURA_JWT_EXPIRY=24h

# Enable bearer-token authentication on all API endpoints.
# When false, the API runs in open-access mode (suitable for localhost dev only).
# Default: false (auth is implicitly enabled when AGENT_API_TOKEN is set)
AUTH_ENABLED=false

# MCP server configuration file path.
# Default: ./.mcp.json
AURA_MCP_CONFIG_PATH=./.mcp.json

# Auto-provision missing MCP servers on startup.
# Default: false
AURA_AUTO_PROVISION_MCP=false

# Auto-start configured MCP servers on AURA startup.
# Default: false
AURA_AUTO_START_MCP_SERVERS=false


# =============================================================================
# External Services
# =============================================================================

# ── GitHub ────────────────────────────────────────────────────────────────────

# GitHub Personal Access Token — used by agents for repo operations and the
# GitHub MCP bridge (aura_cli/mcp_github_bridge.py).
# [secret]
GITHUB_TOKEN=your-github-token

# Alias used by the GitHub MCP bridge directly.
# When both are set, GITHUB_PERSONAL_ACCESS_TOKEN takes precedence in the bridge.
GITHUB_PERSONAL_ACCESS_TOKEN=your-github-pat

# Secret for validating incoming GitHub webhook payloads.
# [secret]
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── n8n Integration ───────────────────────────────────────────────────────────

# Base URL of the n8n instance (used by AURA agents for workflow triggers).
N8N_WEBHOOK_URL=http://localhost:5678

# Shared secret for AURA → n8n webhook calls (HMAC-SHA256 signature validation).
# [secret]
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# Notification webhook URL (set automatically when the Notification Hub workflow
# is active in n8n; see .env.n8n for details).
# N8N_NOTIFY_WEBHOOK_URL=http://localhost:5678/webhook/aura-notify

# n8n webhook URL passed to agents via AURA_N8N_WEBHOOK_URL.
# Distinct from N8N_WEBHOOK_URL: this is the AURA-specific n8n endpoint.
# AURA_N8N_WEBHOOK_URL=http://localhost:5678/webhook/aura

# Auth header value sent with AURA → n8n requests (e.g. "Bearer <token>").
# AURA_N8N_AUTH_HEADER=Bearer your-n8n-api-key

# Enable/disable the n8n integration entirely.
# Default: false
AURA_N8N_ENABLED=false

# Timeout in seconds for AURA → n8n webhook calls.
# Default: 30
AURA_N8N_TIMEOUT_SECONDS=30

# ── Web UI ────────────────────────────────────────────────────────────────────

WEB_UI_URL=http://localhost:3000
WEB_API_URL=http://localhost:8000

# ── Brave Search ──────────────────────────────────────────────────────────────

# Brave Search API key — used by research and investigation agents.
# [secret]
BRAVE_API_KEY=your-brave-api-key
